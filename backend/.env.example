# =========================================================================
# Command Centre backend configuration. Copy to .env; never commit real values.
# =========================================================================

# Which tier to run: mvp | demo | production  (default: mvp)
DJANGO_ENV=mvp

# -- Core -----------------------------------------------------------------
DJANGO_SECRET_KEY=change-me                 # REQUIRED in production
DJANGO_DEBUG=true                           # force false in production
DJANGO_ALLOWED_HOSTS=*                       # REQUIRED in production, e.g. api.example.com
LOG_LEVEL=INFO

# -- CORS / CSRF (production locks these down) ----------------------------
CORS_ALLOWED_ORIGINS=https://app.commandcentre.ng
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.commandcentre.ng

# -- Database (production → PostgreSQL; leave unset for SQLite) ------------
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# -- Cache / channels (production) ----------------------------------------
REDIS_URL=                                   # e.g. redis://localhost:6379/0

# -- Rate limiting (per-tier defaults exist; override here) ---------------
THROTTLE_ANON=30/min
THROTTLE_USER=300/min

# -- Auth (production) ----------------------------------------------------
API_KEYS=                                    # comma-separated machine keys
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=7

# -- Monnify (SANDBOX shown) ----------------------------------------------
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=your_sandbox_api_key
MONNIFY_SECRET_KEY=your_sandbox_secret_key
MONNIFY_CONTRACT_CODE=your_contract_code
MONNIFY_REDIRECT_URL=http://localhost:3000/billing/callback
