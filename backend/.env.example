# =========================================================================
# Command Centre backend configuration. Copy to .env; never commit real values.
# =========================================================================

# Which tier to run: mvp | demo | production  (default: mvp)
DJANGO_ENV=mvp

# -- Core -----------------------------------------------------------------
DJANGO_SECRET_KEY=change-me                 # REQUIRED in production
DJANGO_DEBUG=true                           # force false in production
DJANGO_ALLOWED_HOSTS=*                       # REQUIRED in production, e.g. api.example.com
LOG_LEVEL=INFO

# -- CORS / CSRF (production locks these down) ----------------------------
CORS_ALLOWED_ORIGINS=https://app.commandcentre.ng
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.commandcentre.ng

# -- Database (production → PostgreSQL; leave unset for SQLite) ------------
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# -- Cache / channels (production) ----------------------------------------
REDIS_URL=                                   # e.g. redis://localhost:6379/0

# -- Adapters: mock vs live -----------------------------------------------
# Comma-separated channel keys to run against the REAL platform API instead of
# the mock adapter. Empty (default) = everything mock (safe demo). A channel
# listed here still falls back to mock until its credentials are configured.
# Channel keys: whatsapp,instagram,facebook,tiktok,linkedin,x,google
LIVE_CHANNELS=

# -- Rate limiting (per-tier defaults exist; override here) ---------------
THROTTLE_ANON=30/min
THROTTLE_USER=300/min

# -- Auth (production) ----------------------------------------------------
API_KEYS=                                    # comma-separated machine keys
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=7

# -- Monnify (SANDBOX shown) ----------------------------------------------
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=your_sandbox_api_key
MONNIFY_SECRET_KEY=your_sandbox_secret_key
MONNIFY_CONTRACT_CODE=your_contract_code
MONNIFY_REDIRECT_URL=http://localhost:3000/billing/callback

# -- WhatsApp Cloud API (Meta) ---------------------------------------------
# From the Meta App Dashboard (WhatsApp -> API Setup / System Users).
# WHATSAPP_ACCESS_TOKEN/PHONE_NUMBER_ID/WABA_ID below are a fallback single
# global connection (e.g. your own test number). Once a tenant completes
# Embedded Signup (the "Connect account" popup in Settings), their own
# access token/phone_number_id/waba_id are stored per-tenant on their
# ChannelConnection and take priority over these — see WhatsAppConfig.resolve().
WHATSAPP_ACCESS_TOKEN=                       # long-lived system-user token
WHATSAPP_PHONE_NUMBER_ID=                    # the verified sending number's ID
WHATSAPP_WABA_ID=                            # WhatsApp Business Account ID
WHATSAPP_APP_SECRET=                         # App Dashboard -> Settings -> Basic
                                              # (also signs the Embedded Signup code exchange)
WHATSAPP_VERIFY_TOKEN=                       # any string you invent; re-enter it
                                              # in the Meta webhook verification step
WHATSAPP_GRAPH_API_VERSION=v21.0

# -- WhatsApp Embedded Signup (lets a tenant connect their OWN WhatsApp -----
# -- number via a Facebook popup, instead of you sharing one token) ---------
# developers.facebook.com -> your app -> WhatsApp -> Embedded Signup, to
# create a "Login Configuration" (App ID and Config ID are both public,
# client-side values — not secrets).
WHATSAPP_APP_ID=                             # Meta App ID (App Dashboard -> Settings -> Basic)
WHATSAPP_CONFIG_ID=                          # WhatsApp Embedded Signup Login Configuration ID

# -- OAuth: connect a tenant's real account (Facebook, Instagram, X, --------
# -- LinkedIn, Google, TikTok) -----------------------------------------------
# WhatsApp isn't here — it authenticates via the system-user token above,
# not per-user OAuth. Every provider requires the exact redirect URI below
# to be pre-registered in its developer console:
#   {PUBLIC_APP_URL}/api/oauth/<channel>/callback/
# PUBLIC_APP_URL must be the https origin real users reach this app at (your
# tunnel or production domain) — leave it as localhost:3000 for local testing
# against providers that allow an http localhost redirect (most don't; you'll
# need a tunnel to actually complete a live OAuth round trip).
PUBLIC_APP_URL=http://localhost:3000

# Facebook + Instagram share one Meta app (developers.facebook.com -> My Apps
# -> Add Product -> Facebook Login). Instagram professional accounts connect
# through the linked Facebook Page, so INSTAGRAM_CLIENT_ID/SECRET are optional
# — leave unset and it reuses the Facebook app.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# X: developer.twitter.com -> Project/App -> User authentication settings ->
# OAuth 2.0 (confidential client, "Web App" type).
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn: www.linkedin.com/developers/apps -> your app -> Auth tab.
# Needs the "Sign In with LinkedIn using OpenID Connect" and "Share on
# LinkedIn" products added for the openid/profile/email/w_member_social scopes.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Google: console.cloud.google.com -> APIs & Services -> Credentials ->
# OAuth client ID (Web application). Enable the "Google Business Profile
# API" for the business.manage scope this app requests (review replies).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TikTok: developers.tiktok.com -> Manage apps -> Login Kit.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
