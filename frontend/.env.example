# Leave this UNSET (recommended). The app then calls the API on its own origin
# and Next.js proxies /api and /webhooks to the Django backend (see
# next.config.mjs). This is what lets a single exposed port / tunnel to :3000
# serve the whole app to an external tester.
#
# Only set this if you want the browser to call a separate backend host directly
# (you'd also be responsible for CORS on that host):
# NEXT_PUBLIC_API_BASE=http://localhost:8000

# Where the Next.js proxy forwards API calls, server-side. Defaults to
# http://localhost:8000. Change only if Django runs elsewhere.
# BACKEND_ORIGIN=http://localhost:8000
